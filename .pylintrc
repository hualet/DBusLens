[MAIN]
py-version=3.12

[FORMAT]
max-line-length=100

[MESSAGES CONTROL]
disable=
    consider-using-with,
    duplicate-code,
    import-outside-toplevel,
    line-too-long,
    missing-class-docstring,
    missing-function-docstring,
    missing-module-docstring,
    no-name-in-module,
    too-many-arguments,
    too-many-branches,
    too-many-instance-attributes,
    too-many-lines,
    too-many-locals,
    too-many-return-statements,
    too-many-statements
